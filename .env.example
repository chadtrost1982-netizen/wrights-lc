# Self-hosted OSRM endpoint
VITE_OSRM_BASE_URL=https://router.project-osrm.org

# OneDrive Graph auto-save (Option 1)
# Required for phone+desktop automated saves
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
# Local dev:
# VITE_AZURE_REDIRECT_URI=http://localhost:5173
# Production:
# VITE_AZURE_REDIRECT_URI=https://your-app-domain.vercel.app
VITE_AZURE_REDIRECT_URI=http://localhost:5173
# Folder path inside OneDrive root, example:
# Business/WRIGHTS LC/Invoices
VITE_ONEDRIVE_TARGET_PATH=
